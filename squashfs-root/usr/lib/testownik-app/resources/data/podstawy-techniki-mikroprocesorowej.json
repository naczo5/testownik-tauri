          "text": "do pamięci może się odwoływać bezpośrednio duża liczba rozkazów"
        },
        {
          "key": "f",
          "text": "mniejsza od RISC częstotliwość taktowania procesora"
        },
        {
          "key": "g",
          "text": "powolne działanie dekodera rozkazów"
        },
        {
          "key": "h",
