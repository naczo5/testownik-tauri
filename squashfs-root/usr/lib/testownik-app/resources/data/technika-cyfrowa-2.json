        {
          "key": "b",
          "text": "F = (!x2&!x1&!x0) # (!x2&x1&!x0) # (x2&!x1&!x0) # (x2&x1&x0)"
        },
        {
          "key": "c",
          "text": "F = (!x2#!x1#!x0) $ (!x2#x1#!x0) $ (x2#!x1#!x0) $ (x2#x1#x0)"
        },
        {
          "key": "d",
          "text": "F = [x2..0] : [0,2,4,7]"
